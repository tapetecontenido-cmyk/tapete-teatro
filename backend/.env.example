# ── BACKEND (.env) ──────────────────────────────────────────────────────
# Copiar como: backend/.env

# Servidor
PORT=3001
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=genera-un-string-aleatorio-muy-largo-aqui-min-64-chars

# ── Firebase Admin SDK ──────────────────────────────────────────────────
# Obtener desde: Firebase Console → Configuración → Cuentas de servicio → Generar clave privada

FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_PRIVATE_KEY_ID=abc123
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789

# ── Email — Resend (recomendado, gratis 100 emails/día) ─────────────────
# Obtener API Key en: resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tapeteteatro.com

# ── Email — Gmail (alternativa si no usas Resend) ───────────────────────
# GMAIL_USER=tapeteteatro@gmail.com
# GMAIL_PASS=tu-app-password-de-google

# ── VerificaPago.com (opcional) ─────────────────────────────────────────
# Activa desde el panel admin en /admin/configuracion
VERIFICAPAGO_API_KEY=
VERIFICAPAGO_ENDPOINT=https://api.verificapago.com/v1/verificar
VERIFICAPAGO_ACTIVO=false
